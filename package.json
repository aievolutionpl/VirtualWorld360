{
    "name": "virtualworld-360",
    "version": "1.0.0",
    "author": "AI Evolution Polska <contact@aievolutionpolska.pl>",
    "homepage": "https://aievolutionpolska.pl",
    "repository": {
        "type": "git",
        "url": "https://github.com/aievolutionpl/VirtualWorld360.git"
    },
    "description": "AI-powered immersive 360° virtual world platform — generate, explore and share stunning panoramic environments",
    "keywords": [
        "360", "panorama", "ai", "virtual-reality", "three.js",
        "gpt-image-2", "openai", "immersive", "vr", "ai-evolution-polska"
    ],
    "license": "MIT",
    "main": "api-server.js",
    "scripts": {
        "start": "node api-server.js",
        "dev": "node api-server.js",
        "build": "rollup -c",
        "watch": "rollup -c -w",
        "serve": "serve dist -C",
        "develop": "cross-env BUILD_TYPE=debug concurrently --kill-others \"npm run watch\" \"npm run serve\"",
        "lint": "eslint src"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "devDependencies": {
        "@playcanvas/eslint-config": "2.1.0",
        "@playcanvas/splat-transform": "1.10.2",
        "@playcanvas/pcui": "5.8.0",
        "@rollup/plugin-alias": "6.0.0",
        "@rollup/plugin-image": "3.0.3",
        "@rollup/plugin-json": "6.1.0",
        "@rollup/plugin-node-resolve": "16.0.3",
        "@rollup/plugin-strip": "3.0.4",
        "@rollup/plugin-terser": "0.4.4",
        "@rollup/plugin-typescript": "12.3.0",
        "@types/wicg-file-system-access": "2023.10.7",
        "@typescript-eslint/eslint-plugin": "8.59.0",
        "@typescript-eslint/parser": "8.59.0",
        "autoprefixer": "10.5.0",
        "concurrently": "9.2.1",
        "cors": "2.8.6",
        "cross-env": "10.1.0",
        "eslint": "9.39.4",
        "eslint-import-resolver-typescript": "4.4.4",
        "globals": "17.5.0",
        "i18next": "25.10.10",
        "i18next-browser-languagedetector": "8.2.1",
        "i18next-http-backend": "3.0.6",
        "mediabunny": "1.40.1",
        "playcanvas": "2.18.0",
        "postcss": "8.5.10",
        "rollup": "4.60.2",
        "rollup-plugin-scss": "4.0.1",
        "sass": "1.99.0",
        "serve": "14.2.6",
        "tslib": "2.8.1",
        "typescript": "5.9.3"
